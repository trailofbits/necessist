		require.NoError(t, err)

		_, _, err = m.MarkConfirmedAndReorgedTransactions(1)
		require.NoError(t, err)
		tests.AssertLogEventually(t, observedLogs, "Another confirmed transaction with the same nonce exists")
	})`
