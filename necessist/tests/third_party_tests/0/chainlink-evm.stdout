			return
		}).WSURL().String()

		ethClient := mustNewChainClient(t, wsURL)

		errType, err := ethClient.SendTransactionReturnCode(tests.Context(t), tx, fromAddress)
		assert.Error(t, err)
		assert.Equal(t, multinode.Fatal, errType)
	})`
