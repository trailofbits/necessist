		tc := &reaperConfig{reaperThreshold: 0 * time.Second}

		r := newReaper(t, txStore, tc)

		err := r.ReapTxes(42)
		assert.NoError(t, err)

		txmgrtest.AssertCount(t, db, "evm.txes", 1)
	})`
