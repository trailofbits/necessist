		attempt, err := ab.NewAgnosticBumpAttempt(t.Context(), lggr, tx, false)
		require.NoError(t, err)
		assert.Equal(t, tx.ID, attempt.TxID)
		mockEstimator.AssertExpectations(t)
	})`
