				latest := rand.Int64()
				lp.latestBlock = latest

				latestBlock, err := cpBlue.LatestBlockHeight(ctx)
				require.NoError(t, err)
				assert.Equal(t, uint64(latest), latestBlock)

				latestBlock, err = cpGreen.LatestBlockHeight(ctx)
				require.NoError(t, err)
				assert.Equal(t, uint64(latest), latestBlock)
			})
		})`
