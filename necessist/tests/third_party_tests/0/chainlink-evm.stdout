		assert.NotNil(t, a.Fee.GasPrice)
		assert.Equal(t, "100 wei", a.Fee.GasPrice.String())
		assert.Nil(t, a.Fee.GasTipCap)
		assert.Nil(t, a.Fee.GasFeeCap)
		assert.Equal(t, specifiedGasLimit, a.GasLimit)
	})`
